# Copy to .env in the project root and fill in from Supabase: Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
# Web password-reset link target (must match Supabase Auth redirect URLs)
EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URL=https://budgetapp-flame.vercel.app/reset-password
